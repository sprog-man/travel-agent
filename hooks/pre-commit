#!/bin/sh
# pre-commit — Three-layer verification gate.
# Installed via: git config core.hooksPath hooks

# Skip in CI environments
if [ "$CI" = "true" ]; then
  echo "=== pre-commit: skipping in CI environment ==="
  exit 0
fi

# ---- Layer 1: Lint + TypeScript typecheck ----
echo ""
echo "=== pre-commit: lint & typecheck ==="
echo ""

if [ -f "lint_check.sh" ]; then
  bash lint_check.sh
  if [ $? -ne 0 ]; then
    echo ""
    echo "=== COMMIT REJECTED: lint/typecheck failed ==="
    echo "To bypass (emergency only): git commit --no-verify"
    echo ""
    exit 1
  fi
fi

# ---- Layer 2: Doc sync check ----
echo ""
echo "=== pre-commit: checking doc sync ==="
echo ""

if [ -f "done_check.sh" ]; then
  bash done_check.sh
  if [ $? -ne 0 ]; then
    echo ""
    echo "=== COMMIT REJECTED: doc sync failed ==="
    echo "Fix the issues above, stage changes, and commit again."
    echo "To bypass (emergency only): git commit --no-verify"
    echo ""
    exit 1
  fi
fi

# ---- Layer 3: Static verification (verify.py) ----
# NOTE: This is NOT the full Evaluator agent verification (which includes Playwright MCP).
# This only runs verify.py's static checks at commit time.
# Determine which feature is being committed based on staged file paths.
# Only verify that specific feature. Skip if no feature can be determined.
if [ -f "verify.py" ]; then
  STAGED=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null)

  # Map staged files to feature IDs
  FEATURE_ID=""
  FRONTEND_FILES=$(echo "$STAGED" | grep -E '^frontend/' || true)
  BACKEND_FILES=$(echo "$STAGED" | grep -E '^backend/' || true)

  if [ -n "$FRONTEND_FILES" ]; then
    # Check which frontend feature this belongs to
    if echo "$FRONTEND_FILES" | grep -qE '(Main\.tsx|ChatPanel\.tsx|GlobeHeatmap|GlobeDaylight|useWebSocket|services/api\.ts)'; then
      FEATURE_ID="feat-002"
    elif echo "$FRONTEND_FILES" | grep -qE '(Landing\.tsx|Globe\.tsx|App\.tsx|main\.tsx|package\.json|tsconfig\.json|vite\.config|tailwind\.config|postcss\.config|index\.html|globals\.css|index\.css)'; then
      FEATURE_ID="feat-001"
    fi
  fi

  if [ -n "$BACKEND_FILES" ]; then
    if echo "$BACKEND_FILES" | grep -qE '(nodes/intent|nodes/planning|nodes/image_enrich|nodes/review|nodes/output)'; then
      FEATURE_ID="feat-006"
    elif echo "$BACKEND_FILES" | grep -qE '(tools/amap_mcp|tools/tavily|tools/unsplash|tools/currency)'; then
      FEATURE_ID="feat-004"
    elif echo "$BACKEND_FILES" | grep -qE '(agent/graph|agent/state|schemas/travel|main\.py)'; then
      FEATURE_ID="feat-003"
    elif echo "$BACKEND_FILES" | grep -qE '(llm/base|llm/openai|llm/anthropic|llm/factory|output/|SettingsPanel|docker-compose|README|config/llm)'; then
      FEATURE_ID="feat-008"
    elif echo "$BACKEND_FILES" | grep -qE '(observability/logger|observability/metrics)'; then
      FEATURE_ID="feat-009"
    fi
  fi

  if [ -n "$FEATURE_ID" ]; then
    echo ""
    echo "=== pre-commit: running static checks (verify.py) for $FEATURE_ID ==="
    echo ""

    if [ -f ".venv/Scripts/python.exe" ]; then
      VERIFY_PY=".venv/Scripts/python.exe"
    elif [ -f ".venv/bin/python" ]; then
      VERIFY_PY=".venv/bin/python"
    else
      VERIFY_PY="python"
    fi

    if command -v timeout >/dev/null 2>&1; then
      timeout 30 "$VERIFY_PY" verify.py --feature "$FEATURE_ID"
      VERIFY_RESULT=$?
    elif command -v gtimeout >/dev/null 2>&1; then
      gtimeout 30 "$VERIFY_PY" verify.py --feature "$FEATURE_ID"
      VERIFY_RESULT=$?
    else
      "$VERIFY_PY" verify.py --feature "$FEATURE_ID"
      VERIFY_RESULT=$?
    fi

    if [ $VERIFY_RESULT -ne 0 ]; then
      echo ""
      echo "=== COMMIT REJECTED: verify.py check failed for $FEATURE_ID ==="
      echo "Fix the issues above, stage changes, and commit again."
      echo "To bypass (emergency only): git commit --no-verify"
      echo ""
      exit 1
    fi
  else
    echo ""
    echo "=== pre-commit: skipping verify.py (harness/template config only) ==="
  fi
fi

echo "=== pre-commit: OK ==="
exit 0
